<MDRaisedButton>:
    theme_text_color: "Custom"
    font_size: "14sp"
    elevation_normal: 2
    corner_radius: dp(6)
    padding: [dp(10), dp(5)]
    
<MDFlatButton>:
    theme_text_color: "Custom"
    font_size: "13sp"
    
<MDTextField>:
    mode: "fill"
    fill_color: [0.15, 0.15, 0.2, 1]
    line_color_normal: [0.3, 0.3, 0.4, 1]
    line_color_focus: [1, 0.65, 0, 1]
    text_color_normal: [0.8, 0.8, 0.8, 1]
    text_color_focus: [1, 1, 1, 1]
    hint_text_color_normal: [0.5, 0.5, 0.5, 1]
    hint_text_color_focus: [1, 0.65, 0, 1]
    font_size: "14sp"
    corner_radius: dp(6)
    
<OneLineListItem>:
    theme_text_color: "Custom"
    text_color: [1, 1, 1, 1]
    height: dp(40)  # Уменьшаем высоту элементов списка
    corner_radius: dp(6)
    padding: [dp(10), dp(5)]
    
    on_release:
        self.bg_color = [0.3, 0.2, 0.4, 1]  # Фиолетовый при нажатии

<MDDialog>:
    md_bg_color: [0.15, 0.15, 0.2, 1]
    corner_radius: dp(15)

<MDDialogTitle>:
    theme_text_color: "Custom"
    text_color: [1, 0.65, 0, 1]  # Оранжевый
    font_size: "18sp"
    bold: True
        
<MDDialogContent>:
    theme_text_color: "Custom"
    text_color: [1, 1, 1, 1]

<MDSeparator>:
    color: [0.3, 0.2, 0.5, 1]

<MDCard>:
    md_bg_color: [0.1, 0.1, 0.15, 1]
    corner_radius: dp(10)

<MDTopAppBar>:
    md_bg_color: [0.15, 0.1, 0.25, 1]
    specific_text_color: [1, 1, 1, 1]
    elevation: 2
    height: dp(56)

<MDTabs>:
    background_color: [0.1, 0.1, 0.15, 1]
    tab_bar_height: dp(48)
    indicator_color: [1, 0.65, 0, 1]

<MDTabsLabel>:
    theme_text_color: "Custom"
    text_color_unselected: [0.7, 0.7, 0.7, 1]
    text_color_selected: [1, 0.65, 0, 1]  # Оранжевый для выбранной вкладки
    font_size: "14sp"