<DeleteConfirmDialog>:
    size_hint: None, None
    size: dp(400), dp(200)
    md_bg_color: [0.15, 0.15, 0.2, 1]

    MDLabel:
        text: 'Вы уверены, что хотите удалить эту запись?'
        halign: 'center'
        size_hint_y: None
        height: dp(50)
        theme_text_color: 'Custom'
        text_color: [1, 1, 1, 1]

    MDBoxLayout:
        size_hint_y: None
        height: dp(50)
        spacing: dp(10)

        MDFlatButton:
            text: 'ОТМЕНА'
            theme_text_color: 'Custom'
            text_color: [0.7, 0.7, 0.7, 1]
            on_release: root.dismiss()

        MDRaisedButton:
            text: 'УДАЛИТЬ'
            md_bg_color: [0.8, 0.2, 0.2, 1]
            text_color: [1, 1, 1, 1]
            on_release: root.confirm_delete()